{
    "name": "lubrimotos/nomina",
    "description": "Sistema web de gestión de nómina para Lubrimotos del Sur",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Gabriel Iván Madrigal Flores",
            "email": "wizardxxdd110@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public public/index.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
