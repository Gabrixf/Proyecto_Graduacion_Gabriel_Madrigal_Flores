# ============================================================
# Copia este archivo como .env y ajusta los valores.
# NUNCA subas .env al repositorio.
# ============================================================

# Entorno de ejecución: development | production
APP_ENV=development
APP_NAME="Lubrimotos del Sur - Nómina"
APP_BASE_PATH=

# Base de datos MySQL (XAMPP por defecto)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lubrimotos_nomina
DB_USER=root
DB_PASS=

# Configuración de sesiones
SESSION_NAME=lubrimotos_session
SESSION_LIFETIME=3600

# Logging
LOG_LEVEL=debug
LOG_PATH=logs/app.log

# Zona horaria (Costa Rica no usa horario de verano)
APP_TIMEZONE=America/Costa_Rica
