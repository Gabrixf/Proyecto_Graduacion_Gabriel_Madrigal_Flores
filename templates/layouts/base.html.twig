<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block titulo %}{{ titulo ?? 'Inicio' }}{% endblock %} — {{ app_name }}</title>

    {# Bootstrap 5 CDN #}
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">

    {# Bootstrap Icons #}
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {# Estilos propios #}
    <link rel="stylesheet" href="{{ base_url() }}/assets/css/app.css">

    {% block estilos %}{% endblock %}
</head>
<body class="bg-light">

{# ── Navbar ───────────────────────────────────────────── #}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">

        {# Logo / marca #}
        <a class="navbar-brand fw-bold" href="{{ path_for('dashboard') }}">
            <i class="bi bi-tools me-1"></i> Lubrimotos
        </a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">

            {# Menú principal — solo si hay sesión activa #}
            {% if session.usuario_id is defined %}
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link" href="{{ path_for('dashboard') }}">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </li>

                {# ── Menú solo para admin ─────────────────── #}
                {% if session.usuario_rol == 'admin' %}

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-sliders me-1"></i>Mantenimientos
                    </a>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="{{ path_for('puestos.index') }}">
                                <i class="bi bi-briefcase me-1"></i>Puestos
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="{{ path_for('periodos.index') }}">
                                <i class="bi bi-calendar-range me-1"></i>Períodos de Pago
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="{{ path_for('feriados.index') }}">
                                <i class="bi bi-calendar-x me-1"></i>Feriados
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="{{ path_for('usuarios.index') }}">
                                <i class="bi bi-person-gear me-1"></i>Usuarios
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-people me-1"></i>Empleados
                    </a>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-clipboard2-check me-1"></i>Operaciones
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#"><i class="bi bi-clock-history me-1"></i>Asistencia</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-alarm me-1"></i>Horas Extra</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-sun me-1"></i>Vacaciones</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-bandaid me-1"></i>Incapacidades</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-door-open me-1"></i>Permisos</a></li>
                    </ul>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-cash-coin me-1"></i>Nómina
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#"><i class="bi bi-receipt me-1"></i>Gestionar Nóminas</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-gift me-1"></i>Aguinaldo</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-file-earmark-break me-1"></i>Liquidaciones</a></li>
                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-star-half me-1"></i>Evaluaciones
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-graph-up me-1"></i>Reportes
                    </a>
                </li>

                {% else %}
                {# ── Menú para colaborador ─────────────────── #}
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-person-lines-fill me-1"></i>Mi Perfil
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-receipt me-1"></i>Mis Colillas
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-sun me-1"></i>Mis Vacaciones
                    </a>
                </li>
                {% endif %}

            </ul>

            {# Info de usuario + logout #}
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>
                        {{ session.usuario_nombre ?? 'Usuario' }}
                        <span class="badge bg-secondary ms-1">{{ session.usuario_rol }}</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item text-danger" href="{{ path_for('auth.logout') }}">
                                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

            {% endif %} {# fin si hay sesión #}

        </div>
    </div>
</nav>

{# ── Contenido principal ──────────────────────────────── #}
<main class="container py-4">

    {# Breadcrumb (opcional) #}
    {% block breadcrumb %}{% endblock %}

    {# Mensajes flash globales (también accesibles desde cualquier módulo) #}
    {% if flashSuccess is defined and flashSuccess %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-1"></i> {{ flashSuccess }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    {% if flashError is defined and flashError %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> {{ flashError }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    {% block contenido %}{% endblock %}

</main>

{# ── Footer ───────────────────────────────────────────── #}
<footer class="bg-dark text-secondary text-center py-3 mt-4 small">
    {{ app_name }} &copy; {{ "now"|date("Y") }} &mdash; Uso interno
</footer>

{# Bootstrap 5 JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmP0HYKPge6eMPtSARDHkXMxDvEL"
        crossorigin="anonymous"></script>

{# JS propio #}
<script src="{{ base_url() }}/assets/js/app.js"></script>

{% block scripts %}{% endblock %}
</body>
</html>
