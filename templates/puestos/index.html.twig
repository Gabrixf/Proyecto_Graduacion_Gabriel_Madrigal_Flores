{% extends 'layouts/base.html.twig' %}

{% block titulo %}Puestos de Trabajo{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ url_for('dashboard') }}">Dashboard</a></li>
        <li class="breadcrumb-item">Mantenimientos</li>
        <li class="breadcrumb-item active">Puestos</li>
    </ol>
</nav>
{% endblock %}

{% block contenido %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-briefcase me-2 text-primary"></i>Puestos de Trabajo
    </h2>
    <a href="{{ url_for('puestos.create') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Puesto
    </a>
</div>

{% if puestos|length == 0 %}
<div class="alert alert-info">
    <i class="bi bi-info-circle me-1"></i>
    No hay puestos registrados. Haga clic en <strong>Nuevo Puesto</strong> para agregar el primero.
</div>
{% else %}
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Nombre del Puesto</th>
                    <th scope="col" class="text-end">Salario Base (₡)</th>
                    <th scope="col">Descripción</th>
                    <th scope="col" class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for puesto in puestos %}
                <tr>
                    <td class="text-muted small">{{ puesto.id_puesto }}</td>
                    <td class="fw-semibold">{{ puesto.nombre }}</td>
                    <td class="text-end font-monospace">
                        {{ puesto.salario_base|number_format(2, '.', ',') }}
                    </td>
                    <td class="text-muted small">
                        {{ puesto.descripcion ?? '—' }}
                    </td>
                    <td class="text-center">
                        <a href="{{ url_for('puestos.edit', {'id': puesto.id_puesto}) }}"
                           class="btn btn-sm btn-outline-primary me-1"
                           title="Editar">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        {# Botón que abre modal de confirmación #}
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                title="Eliminar"
                                data-bs-toggle="modal"
                                data-bs-target="#modalEliminar"
                                data-id="{{ puesto.id_puesto }}"
                                data-nombre="{{ puesto.nombre }}">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted small">
        Total: {{ puestos|length }} puesto(s) registrado(s).
    </div>
</div>
{% endif %}

{# ── Modal de confirmación de eliminación ──────────────── #}
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalEliminarLabel">
                    <i class="bi bi-exclamation-triangle me-1"></i>Confirmar eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                ¿Está seguro de que desea eliminar el puesto
                <strong id="modalNombrePuesto"></strong>?
                Esta acción no se puede deshacer.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <form id="formEliminar" method="POST" action="">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3 me-1"></i>Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
// Cargar datos del puesto en el modal de eliminación
document.getElementById('modalEliminar').addEventListener('show.bs.modal', function (event) {
    const btn    = event.relatedTarget;
    const id     = btn.getAttribute('data-id');
    const nombre = btn.getAttribute('data-nombre');

    document.getElementById('modalNombrePuesto').textContent = '"' + nombre + '"';
    document.getElementById('formEliminar').action =
        '/mantenimientos/puestos/' + id + '/eliminar';
});
</script>
{% endblock %}
